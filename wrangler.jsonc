{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pulse-ops",
  "main": "worker.js",
  "compatibility_date": "2026-04-29",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "APP_STORE",
      "id": "SUBSTITUA_PELO_ID_DO_KV",
      "preview_id": "SUBSTITUA_PELO_PREVIEW_ID_DO_KV"
    }
  ],
  "vars": {
    "SECRET_KEY": "troque-esta-chave-em-producao"
  }
}
